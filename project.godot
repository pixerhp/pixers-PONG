config_version=5

[application]

config/name="Pixer's Pong"
run/main_scene="uid://hlipoo3a81a4"
config/features=PackedStringArray("4.7", "GL Compatibility")
boot_splash/image="uid://c8njw4gkdiofe"
config/icon="uid://c8njw4gkdiofe"

[autoload]

Globals="*uid://dl6ovnkbgf2b7"

[display]

window/stretch/mode="viewport"
window/stretch/aspect="expand"

[file_customization]

